{
  "name": "soonfx-demo-service",
  "version": "0.1.0",
  "private": true,
  "description": "SoonFx demo service with one-day bootstrap/deploy workflow on Windows.",
  "main": "dist/server.js",
  "scripts": {
    "bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap.ps1",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:perf": "node scripts/perf-test.mjs",
    "deploy-local": "powershell -ExecutionPolicy Bypass -File scripts/deploy-local.ps1",
    "rollback-local": "powershell -ExecutionPolicy Bypass -File scripts/rollback-local.ps1"
  },
  "dependencies": {
    "@soonfx/engine": "^2.0.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.57",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
